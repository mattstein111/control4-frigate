<devicedata>
  <copyright>Copyright 2026. All rights reserved.</copyright>
  <creator>control4-frigate</creator>
  <manufacturer>Frigate NVR</manufacturer>
  <name>Frigate NVR</name>
  <model>Frigate NVR Controller</model>
  <created>2026-03-31</created>
  <modified>2026-04-12</modified>
  <version>38</version>

  <small image_source="c4z">icons/device_sm.png</small>
  <large image_source="c4z">icons/device_lg.png</large>
  <control>lua_gen</control>
  <controlmethod>ip</controlmethod>
  <driver>DriverWorks</driver>

  <proxies qty="1">
    <proxy proxybindingid="5001" name="Frigate NVR">frigate_nvr</proxy>
  </proxies>

  <combo>true</combo>

  <config>
    <properties>
      <property>
        <name>Driver Version</name>
        <type>STRING</type>
        <default></default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Frigate Host</name>
        <type>STRING</type>
        <default></default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Frigate Port</name>
        <type>STRING</type>
        <default>5000</default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Frigate Username</name>
        <type>STRING</type>
        <default></default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Frigate Password</name>
        <type>STRING</type>
        <default></default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>MQTT Broker</name>
        <type>STRING</type>
        <default></default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>MQTT Port</name>
        <type>STRING</type>
        <default>1883</default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>MQTT Username</name>
        <type>STRING</type>
        <default></default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>MQTT Password</name>
        <type>STRING</type>
        <default></default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Use Sub Streams</name>
        <type>LIST</type>
        <items>
          <item>Yes</item>
          <item>No</item>
        </items>
        <default>Yes</default>
        <readonly>false</readonly>
      </property>
      <property>
        <name>Frigate Status</name>
        <type>STRING</type>
        <default>Not Connected</default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>MQTT Status</name>
        <type>STRING</type>
        <default>Not Connected</default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Cameras in Frigate</name>
        <type>STRING</type>
        <default></default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Cameras in Control4</name>
        <type>STRING</type>
        <default>0</default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Managed Cameras</name>
        <type>STRING</type>
        <default></default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Unmatched Cameras</name>
        <type>STRING</type>
        <default></default>
        <readonly>true</readonly>
      </property>
      <property>
        <name>Log Level</name>
        <type>LIST</type>
        <default>2 - Warning</default>
        <readonly>false</readonly>
        <items>
          <item>0 - Fatal</item>
          <item>1 - Error</item>
          <item>2 - Warning</item>
          <item>3 - Info</item>
          <item>4 - Debug</item>
          <item>5 - Trace</item>
        </items>
      </property>
      <property>
        <name>Log Mode</name>
        <type>LIST</type>
        <default>Off</default>
        <readonly>false</readonly>
        <items>
          <item>Off</item>
          <item>Print</item>
          <item>Log</item>
          <item>Print and Log</item>
        </items>
      </property>
    </properties>
    <actions>
      <action>
        <name>Create / Relink Cameras</name>
        <command>CreateCameras</command>
      </action>
      <action>
        <name>Synchronize Cameras with Frigate</name>
        <command>RenameCameras</command>
      </action>
      <action>
        <name>Reconnect MQTT</name>
        <command>ReconnectMQTT</command>
      </action>
      <action>
        <name>Remove All Cameras</name>
        <command>RemoveAllCameras</command>
      </action>
      <action>
        <name>Check Frigate Status</name>
        <command>CheckStatus</command>
      </action>
    </actions>
    <documentation file="www/documentation.html"></documentation>
    <script file="driver.lua"></script>
    <power_management_method>AlwaysOn</power_management_method>
    <power_command_delay>0</power_command_delay>
    <power_delay>0</power_delay>
    <power_command_needed>False</power_command_needed>
  </config>

  <composer_categories>
    <category>Camera</category>
  </composer_categories>
</devicedata>
